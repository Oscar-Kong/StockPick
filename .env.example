# Application environment: development | production
#
# SETUP: cp .env.example .env  then fill in your own API keys.
# NEVER commit .env — it is gitignored. Only this template goes on GitHub.

APP_ENV=development

# --- Public demo (Render + Vercel) — see docs/DEPLOYMENT.md ---
# DEMO_MODE=true
# DEMO_SEED_DATA=true
# DATABASE_URL=sqlite:///./data/stockpick_demo.db
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Database (SQLite default for local; use PostgreSQL in production)
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/stock_picker

# Data source roles
PRIMARY_PRICE_SOURCE=akshare
PRIMARY_FUNDAMENTALS_SOURCE=akshare
PRIMARY_NEWS_SOURCE=finnhub

AKSHARE_ENABLED=true
FINNHUB_ENABLED=true
FMP_ENABLED=true
ALPHA_VANTAGE_ENABLED=true
FRED_ENABLED=true
LLM_ENABLED=true
NASDAQ_DATA_LINK_ENABLED=true

# OpenBB Platform (optional — pip install -r backend/requirements-openbb.txt)
OPENBB_ENABLED=false
# SEC/insider fetches are slow; keep false for fast bulk scans (Analyze page still uses cache/fetch)
OPENBB_ON_SCAN=false
OPENBB_RISK_CACHE_TTL=86400

# Quant framework feature flags (keep false until each phase is shipped)
QLIB_ENABLED=false
VBT_ENABLED=false
PYPFOPT_ENABLED=false
FINRL_ENABLED=false
LEAN_EXPORT_ENABLED=false
REGIME_OVERLAY_ENABLED=true

# Institutional quant v2 (Phase 1+ — see docs/INSTITUTIONAL_QUANT_ARCHITECTURE.md)
SCORE_ENGINE_V2_ENABLED=true
# Workspace analyze caches (seconds)
# ANALYZE_RESULT_TTL=1800
# WATCHLIST_MATRIX_TTL=45
# ANALYZE_ROUTE_TIMEOUT_SECONDS=35
# Interactive /api/v2/score defaults: validate_parity=false, persist_snapshot=false
# (pass query params true for CI / shadow / evaluation jobs)
# Production default: ScoringEngine in scan Stage B.
# Stage B scoring: legacy | engine | parity_sample
# engine = production ScoringEngine only (canonical default)
# parity_sample = engine for ranking + legacy on a deterministic sample for comparison
SCAN_SCORING_MODE=engine
SCAN_PARITY_SAMPLE_RATE=0.10
# Deprecated fallback when SCAN_SCORING_MODE is empty/invalid (prefer SCAN_SCORING_MODE):
USE_SCORING_ENGINE_IN_SCAN=false
# --- Local / staging profile (parity comparison) ---
# APP_ENV=staging
# SCAN_SCORING_MODE=parity_sample
# SCAN_PARITY_SAMPLE_RATE=1.0
# PERSIST_SCORE_ATTRIBUTION=true
# Or: source scripts/staging-scan-engine.env && ./scripts/run-staging-scan-parity.sh --cached
# Watch backend logs for "Scan score parity" (per symbol) and "Scan parity summary" (per scan).
# GET /scan/{job_id} and GET /scan/latest/{bucket} include parity_summary when engine path is active.
PERSIST_SCORE_ATTRIBUTION=true
FACTOR_MODEL_VERSION=quant-v2-round2
DYNAMIC_WEIGHTS_ENABLED=true
IC_PANEL_MAX_SYMBOLS=40
IC_PANEL_FORWARD_DAYS=20
IC_PANEL_HORIZONS=5,20,60,90
WEIGHT_MIN=0.02
WEIGHT_MAX=0.35
IC_SOFTMAX_ALPHA=1.0
IC_SOFTMAX_BETA=0.5
QUANT_JOBS_ENABLED=true
QUANT_IC_CRON=45 20 * * 1-5

# --- Quant Lab research foundation (Phase 2) ---
QUANT_LAB_RESEARCH_API_ENABLED=true
# Factor Discovery (Phase 1+): contracts only until Phase 2; launch returns disabled when false
FACTOR_DISCOVERY_ENABLED=false
# Factor research data provider: disabled | historical_store | fixture (test-only)
FACTOR_RESEARCH_DATA_PROVIDER=disabled
# Staging-only example (do NOT enable in production defaults):
# FACTOR_DISCOVERY_STAGING_ENABLED=true
# FACTOR_RESEARCH_DATA_PROVIDER=historical_store
# FACTOR_DISCOVERY_ENABLED=true
# Factor Discovery LLM layer (Phase 6B): disabled by default; does not enable experiment execution
FACTOR_DISCOVERY_LLM_ENABLED=false
FACTOR_DISCOVERY_LLM_PROVIDER=disabled
# Factor Discovery mining loop (Phase 7): disabled | supervised | bounded_auto
FACTOR_DISCOVERY_LOOP_ENABLED=false
FACTOR_DISCOVERY_LOOP_MODE=disabled
# Max internal workflow steps per advance request (hard cap 10)
FACTOR_DISCOVERY_LOOP_MAX_ADVANCE_STEPS=10
# Phase 9B — staging validation (disabled by default; use CLI with explicit env)
FACTOR_DISCOVERY_STAGING_ENABLED=false
# Phase 10 — promotion governance + shadow scoring (advisory; no live scan mutation)
FACTOR_PROMOTION_GOVERNANCE_ENABLED=false
FACTOR_SHADOW_SCORING_ENABLED=false
# FACTOR_RESEARCH_SNAPSHOT_ROOT=backend/data/factor_discovery/snapshots
# FACTOR_RESEARCH_STAGING_INPUT_ROOT=backend/data/factor_discovery/staging_input
# FACTOR_RESEARCH_STAGING_AUDIT_ROOT=backend/data/factor_discovery/staging_audits
# FACTOR_RESEARCH_EXTENDED_STAGING_ROOT=backend/data/factor_discovery/extended_staging
# FACTOR_RESEARCH_ACCEPTANCE_ROOT=backend/data/factor_discovery/acceptance
# FACTOR_RESEARCH_PROMOTION_EVIDENCE_ROOT=backend/data/factor_discovery/promotion_evidence
# FACTOR_RESEARCH_STAGING_DATABASE=
# Max ordinary score modifier from supporting/contradicting evidence (0 = display-only)
RESEARCH_MAX_ORDINARY_MODIFIER=0

# Phase 3 — expanded factors + hard filters (off until validated)
SLEEVE_FACTORS_V3_ENABLED=false
HARD_FILTERS_V3_ENABLED=false
# OpenAlpha-inspired experimental factor legs (see docs/OPENALPHA_INTEGRATION.md)
OPENALPHA_FACTORS_ENABLED=false

RISK_ENGINE_V2=true
POSITION_SIZING_V2=true
SLEEVE_MAX_WEIGHT_PENNY=0.03
SLEEVE_MAX_WEIGHT_COMPOUNDER=0.15
DEFAULT_PORTFOLIO_EXPOSURE=0.5
DEFAULT_ACTIVE_POSITIONS=8
AI_REPORT_SCHEMA=v2
BACKTEST_INSTITUTIONAL=true
BT_FEE_BPS_DEFAULT=5
BT_SLIP_BPS_DEFAULT=10
BT_PARTICIPATION_RATE=0.10
BT_DELISTING_HAIRCUT=0.50
TRADE_FEEDBACK_ENABLED=true
TRADE_FEEDBACK_BAYESIAN_ETA=0.1

# Round 2 — prediction loop + valuation + data confidence gates
PREDICTION_SNAPSHOTS_ENABLED=true
PREDICTION_OUTCOME_HORIZONS=5,20,60,90
DATA_CONFIDENCE_STRONG_REC_MIN=70
DATA_CONFIDENCE_STRONG_BUY_MIN=80
VALUATION_ENGINE_ENABLED=true
MULTI_AGENT_PIPELINE_ENABLED=true
SIMILAR_SIGNAL_TOLERANCE=12
OUTCOME_WEIGHT_FEEDBACK_ENABLED=true
OUTCOME_WEIGHT_ETA=0.05
FORWARD_LABELS_ENABLED=true
LEGACY_BACKTEST_COSTS_ENABLED=true
PIT_FUNDAMENTALS_ENABLED=true
LLM_AGENTS_ENABLED=false

# Phase 7 — production hardening
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/stock_picker
DATABASE_POOL_SIZE=5
SQLITE_SOURCE_PATH=backend/data_store/stock_picker.db
JOB_QUEUE_BACKEND=sync
# JOB_QUEUE_BACKEND=db
# JOB_QUEUE_BACKEND=redis
REDIS_URL=
JOB_QUEUE_REDIS_KEY=stockpicker:jobs
JOB_QUEUE_POLL_SEC=5
AUDIT_LOG_ENABLED=true
MODEL_VERSION_STRICT=false
FACTOR_IC_LOOKBACK_DAYS=60
WEIGHT_REBALANCE_LAMBDA=0.5

# API keys
ALPHA_VANTAGE_API_KEY=your_key_here
FRED_API_KEY=your_key_here
FRED_API_VERSION=v2
FINNHUB_API_KEY=your_finnhub_key_here
FMP_API_KEY=your_fmp_key_here

# Nasdaq Data Link (formerly Quandl) — reference/batch datasets only
NASDAQ_DATA_LINK_API_KEY=your_ndl_key_here
# QUANDL_API_KEY=  # legacy alias for NASDAQ_DATA_LINK_API_KEY

# NewsAPI — dev/test only (set NEWSAPI_ENABLED=false in production)
NEWSAPI_KEY=
NEWSAPI_ENABLED=true

# Reconciliation tolerances (relative difference: 0.01 = 1%)
RECONCILE_PRICE_TOLERANCE=0.01
RECONCILE_RATIO_TOLERANCE=0.12

# Scheduler — post-close batch, US market hours (America/New_York)
# Use false for local dev to avoid background quote refresh load.
SCHEDULER_ENABLED=false
SCHEDULER_TZ=America/New_York
SCHEDULER_CRON=15 20 * * 1-5
SCHEDULER_MARKET_CALENDAR=XNYS

# Morning scan email (9:20 AM ET Mon–Fri; independent of SCHEDULER_ENABLED)
SCAN_EMAIL_ENABLED=false
SCAN_EMAIL_PROVIDER=smtp
SCAN_EMAIL_TO=
# From address should match SMTP_USER (Gmail, 163, QQ, etc.)
SCAN_EMAIL_FROM=StockPick <you@gmail.com>
SCAN_EMAIL_BUCKETS=penny,compounder
SCAN_EMAIL_TOP_N=5
SCAN_EMAIL_CRON=20 9 * * 1-5
SCAN_EMAIL_TIMEZONE=America/New_York
SCAN_EMAIL_STALE_AFTER_MINUTES=1440
SCAN_EMAIL_RETRY_DELAY_MINUTES=5
SCAN_EMAIL_MAX_RETRIES=3
APP_PUBLIC_URL=http://127.0.0.1:18730

# SMTP primary — 163 (China): smtp.163.com port 465 + authorization code (授权码)
# Gmail uses port 587 (STARTTLS). Port 465 uses implicit SSL automatically.
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SCAN_EMAIL_FROM=StockPick <you@163.com>

# SMTP fallback (optional) — e.g. Gmail when primary is blocked
SMTP_FALLBACK_HOST=smtp.gmail.com
SMTP_FALLBACK_PORT=587
SMTP_FALLBACK_USER=
SMTP_FALLBACK_PASSWORD=
SMTP_FALLBACK_USE_TLS=true
SCAN_EMAIL_FROM_FALLBACK=StockPick <you@gmail.com>

# Cache TTL (seconds)
PRICE_CACHE_TTL=300
# Portfolio Today chart + P/L (seconds); 0 disables
PORTFOLIO_PERFORMANCE_CACHE_TTL=120
FUNDAMENTALS_CACHE_TTL=604800
SCAN_RESULT_TTL=900
# Per-bucket overrides for SCAN_RESULT_TTL. Compounder fundamentals change
# slowly, so we cache "latest" much longer than penny. If unset, penny inherits
# SCAN_RESULT_TTL and compounder defaults to 86400 (1 day).
SCAN_RESULT_TTL_PENNY=900
SCAN_RESULT_TTL_COMPOUNDER=86400

# Scan Stage B depth. Lower = faster scans, fewer candidates analyzed.
SCAN_STAGE_B_TOP_N=100
SCAN_STAGE_B_TOP_N_FAST=40
# Max rows returned per scan (UI may request fewer via ScanOptions.max_results).
MAX_CANDIDATES_PER_BUCKET=50
# Hard cap (seconds) on the Stage A bulk OHLC provider fetch.
# yfinance chunks use process-isolated timeouts; empty/partial bulk skips per-symbol Yahoo/AkShare.
# Below SCAN_BULK_COVERAGE_MIN, one bounded FMP fill may run; latest is not overwritten if still partial.
SCAN_PRICE_DOWNLOAD_MAX_SECONDS=300
SCAN_BULK_COVERAGE_MIN=0.70
# Process timeout for single-symbol Yahoo Ticker.info / Ticker.history.
YFINANCE_INFO_TIMEOUT_SECONDS=8
# Stage A / Stage B OHLC horizons (penny: 6mo; compounder: 1y Stage A → 5y Stage B).
SCAN_PENNY_STAGE_A_PERIOD=6mo
SCAN_PENNY_STAGE_B_PERIOD=6mo
SCAN_COMPOUNDER_STAGE_A_PERIOD=1y
SCAN_COMPOUNDER_STAGE_B_PERIOD=5y
# Reuse reconciled fundamental snapshots when younger than N calendar days.
FUNDAMENTAL_SNAPSHOT_MAX_AGE_DAYS=1
# Stop Stage B after this many seconds and return partial ranked results.
# Stage B scoring time cap in seconds (0 = unlimited; set e.g. 900 on slow demo hosts)
SCAN_STAGE_B_TIME_BUDGET_SECONDS=0

# Final ranking weights (per bucket; alpha + confidence + tradability should sum to ~1.0)
SCAN_RANK_ALPHA_WEIGHT_PENNY=0.65
SCAN_RANK_CONFIDENCE_WEIGHT_PENNY=0.20
SCAN_RANK_TRADABILITY_WEIGHT_PENNY=0.15
SCAN_RANK_ALPHA_WEIGHT_COMPOUNDER=0.60
SCAN_RANK_CONFIDENCE_WEIGHT_COMPOUNDER=0.25
SCAN_RANK_TRADABILITY_WEIGHT_COMPOUNDER=0.15
# Portfolio-aware diversification + persistence
SCAN_MAX_PER_SECTOR=3
SCAN_MAX_PER_CORRELATION_CLUSTER=2
SCAN_CORRELATION_CLUSTER_THRESHOLD=0.75
SCAN_PERSISTENCE_DELTA=3.0
SCAN_MIN_RESULTS_AFTER_DIVERSIFICATION=3
SCAN_PENNY_LOW_CONFIDENCE_MAX=2
SCAN_PENNY_LOW_CONFIDENCE_THRESHOLD=45.0

# Strategy traceability
STRATEGY_VERSION=2026-07-sleeve-weights-v1

# Data quality gates (0–100 scale; ~252 trading days = 1 year)
MIN_DATA_QUALITY_SCORE=60
MIN_HISTORY_BARS=252

# Penny bucket
PENNY_MIN_VOLUME=1000000
PENNY_MIN_DOLLAR_VOLUME_20D=1000000
PENNY_MARKET_CAP_MIN=100000000
PENNY_MARKET_CAP_MAX=300000000
# Hard-reject penny names only when intraday range proxy exceeds this % of price (default 15).
PENNY_MAX_SPREAD_PCT=15.0

# Compounder bucket
COMPOUNDER_MARKET_CAP_MIN=10000000000
COMPOUNDER_MIN_REVENUE_GROWTH=0.08

# Cap Stage A symbols per scan. Positive values use a deterministic non-alphabetical
# sample (avoids A–prefix bias). 0 = full validated universe (heavy with large seed lists).
UNIVERSE_SCAN_BATCH_SIZE=100

# Official listing master (Nasdaq Trader symbol directories)
LISTING_MASTER_ENABLED=true
LISTING_MASTER_FETCH_TIMEOUT=20
# Long TTL preserves last-known-good snapshot when refresh fails
LISTING_MASTER_CACHE_TTL=31536000

WATCHLIST_IMPORT_GENERATE_REPORTS=false
# Per-symbol analyze budget for POST /watchlist/import (seconds). Concurrent
# imports are serialized to avoid market-data stampedes.
WATCHLIST_IMPORT_PER_SYMBOL_TIMEOUT_SECONDS=30
# Bound trade-upload side effects so market-data stalls cannot hang the request.
TRADE_UPLOAD_PREDICTION_TIMEOUT_SECONDS=8
TRADE_UPLOAD_DECISION_TIMEOUT_SECONDS=20

# LLM (Proxy-compatible)
# Set these three values only
# Example base URL for WhaleCloud GPT Proxy (verify in your console docs):
# GPT_PROXY_BASE_URL=https://lab.iwhalecloud.com/gpt-proxy/v1
GPT_PROXY_API_KEY=your_proxy_key_here
GPT_PROXY_BASE_URL=https://lab.iwhalecloud.com/gpt-proxy/v1
GPT_PROXY_MODEL=your_proxy_model_here

# Optional generic fallback vars
LLM_MODEL=gpt-4o-mini
LLM_REASONING_EFFORT=low
LLM_VERBOSITY=low
# Optional — proxy-specific tuning (not read by backend config.py today)
# LLM_MAX_TOKENS=12000
# LLM_ENABLE_ADAPTIVE_THINKING=true
INVEST_TIME_HORIZON=1-3 months
INVEST_RISK_TOLERANCE=medium
INVEST_MAX_POSITION_SIZE=5% of portfolio
INVEST_ALLOWED_STRATEGIES=stocks only
INVEST_INTERESTED_SECTORS=
INVEST_AVOID_LIST=

# Robinhood Trading MCP — live portfolio sync (read-only; see docs/ROBINHOOD_MCP.md)
ROBINHOOD_MCP_ENABLED=true
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
ROBINHOOD_MCP_REDIRECT_URI=http://127.0.0.1:8765/callback
# ROBINHOOD_MCP_ACCOUNT_ID=
