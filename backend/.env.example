# Backend environment template — copy to repo root .env for local dev
# On Render, set these in the dashboard (never commit real secrets).

APP_ENV=development

# --- Public demo (Render) ---
# DEMO_MODE=true
# DEMO_SEED_DATA=true
# DATABASE_URL=sqlite:///./data/stockpick_demo.db
# ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Database ---
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/stock_picker

# --- Demo limits (optional overrides) ---
# DEMO_MAX_SCAN_SYMBOLS=75
# DEMO_MAX_ANALYSIS_SYMBOLS=1
# DEMO_MAX_BACKTEST_SYMBOLS=15
# DEMO_MAX_BACKTEST_DAYS=365
# DEMO_MAX_QUANT_JOB_SYMBOLS=25
# DEMO_MAX_REQUESTS_PER_MINUTE=30

# --- CORS (production) ---
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:18730

# --- API keys (backend only — never expose to browser) ---
FINNHUB_API_KEY=your_finnhub_key_here
FMP_API_KEY=your_fmp_key_here
ALPHA_VANTAGE_API_KEY=your_key_here
FRED_API_KEY=your_key_here
GPT_PROXY_API_KEY=your_proxy_key_here
GPT_PROXY_BASE_URL=https://lab.iwhalecloud.com/gpt-proxy/v1
GPT_PROXY_MODEL=your_proxy_model_here

# --- Feature flags ---
OPENBB_ENABLED=false
QLIB_ENABLED=false
VBT_ENABLED=false
PYPFOPT_ENABLED=false
FINRL_ENABLED=false
LEAN_EXPORT_ENABLED=false
SCHEDULER_ENABLED=false
