# Staging profile: ScoringEngine v2 as scan Stage B ranking path (parity mode).
# Does NOT modify production default in .env — source this file for one-off runs only.
#
# Usage:
#   set -a && source scripts/staging-scan-engine.env && set +a
#   ./scripts/run-staging-scan-parity.sh
#
# Or:
#   SCAN_SCORING_MODE=parity_sample SCAN_PARITY_SAMPLE_RATE=1.0 APP_ENV=staging ./scripts/run-staging-scan-parity.sh

APP_ENV=staging
SCAN_SCORING_MODE=parity_sample
SCAN_PARITY_SAMPLE_RATE=1.0
USE_SCORING_ENGINE_IN_SCAN=true
SCORE_ENGINE_V2_ENABLED=true
PERSIST_SCORE_ATTRIBUTION=true
OPENBB_ON_SCAN=false

# Optional: cap universe for faster staging iteration (unset for full universe)
# UNIVERSE_SCAN_BATCH_SIZE=50
